# ── Expense IDP configuration ──────────────────────────────────────────────
# Copy to `.env` and fill in. The core (schemas + deterministic checks + tests)
# runs with NONE of these set — they are only needed once you talk to Azure.

# Model backend: "mock" (default, offline, deterministic) | "foundry" | "azure_openai"
EXPENSE_MODEL_BACKEND=mock

# ── Azure OpenAI / Foundry (vision extractor + agents) ─────────────────────
# Auth is via Azure CLI / Managed Identity (DefaultAzureCredential) — no API keys.
# Run `az login` locally. Use a deployment name that is GenerallyAvailable in your
# region (check: `az cognitiveservices model list --location <region>`).
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<proj>
FOUNDRY_MODEL=gpt-5.4-mini                # default extractor / small-model deployment (vision)
FOUNDRY_MODEL_ESCALATION=gpt-5.4          # bigger model for hard docs / reasoning

# ── Azure AI Search (policy RAG for the Validator) ─────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX=expense-policy

# ── Cosmos DB (expense records + duplicate lookup) ─────────────────────────
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=expenses
COSMOS_CONTAINER=records

# ── Blob Storage (raw receipts) ────────────────────────────────────────────
BLOB_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net
BLOB_CONTAINER=receipts

# ── Approvals (Logic App HTTP trigger for Teams/email HITL) ────────────────
APPROVAL_LOGIC_APP_URL=

# ── Web app ─────────────────────────────────────────────────────────────────
# The app's own public URL (set automatically on Container Apps). When set together
# with APPROVAL_LOGIC_APP_URL, escalations post a Teams card that calls back to
# PUBLIC_BASE_URL/api/approvals/{id}/callback when the human clicks.
PUBLIC_BASE_URL=
APPROVAL_CALLBACK_TOKEN=
# Local fallback record store path (used when COSMOS_ENDPOINT is empty).
LOCAL_STORE_PATH=.localstore/records.json

# ── ERP / GL post (stub function is fine for the demo) ─────────────────────
ERP_POST_URL=

# ── Observability ──────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Business policy thresholds (overridable without code changes) ──────────
AUTO_APPROVE_LIMIT=75            # auto-approve low-risk claims at/under this (base currency)
BASE_CURRENCY=USD
MAX_AGENT_ITERATIONS=8           # cap loops so a runaway can't burn credit
MAX_RECEIPT_AGE_DAYS=90          # older receipts (or future-dated ones) escalate to a human
